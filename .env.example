# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=connecteed
DB_PASSWORD=connecteed_secret
DB_DATABASE=crm_connecteed

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# App
APP_PORT=3000
APP_ENV=development
FRONTEND_URL=http://localhost:5173

# Microsoft SSO (predisposizione)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# DocuSign (predisposizione)
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=

# Fatture in Cloud (predisposizione)
FIC_API_TOKEN=
FIC_COMPANY_ID=

# Email SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@connecteed.com

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
